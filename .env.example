# ──────────────────────────────────────────────────────────────────────
# HandleLife OS — Environment Template
# ──────────────────────────────────────────────────────────────────────
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.

# ── Application ───────────────────────────────────────────────────────
APP_NAME=HandleLifeOS
APP_ENV=production              # local | testing | staging | production
APP_KEY=                        # generate with: php artisan key:generate
APP_DEBUG=false                 # MUST be false in production (leaks stack traces)
APP_URL=https://handlelife.os   # use https:// in production

# ── Logging ───────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning               # info/debug fine in dev; warning+ in prod

# ── Database ──────────────────────────────────────────────────────────
DB_CONNECTION=mysql             # sqlite for local; mysql/pgsql in prod
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=handlelife
DB_USERNAME=
DB_PASSWORD=

# ── Cache / Queue / Session ───────────────────────────────────────────
BROADCAST_DRIVER=log
CACHE_STORE=redis               # redis recommended for prod (rate limiter)
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

# ── Session security (CRITICAL in production) ─────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true            # encrypt session payload at rest
SESSION_SECURE_COOKIE=true      # HTTPS-only cookies
SESSION_HTTP_ONLY=true          # JS cannot read session cookie
SESSION_SAME_SITE=strict        # strongest CSRF protection
SESSION_DOMAIN=.handlelife.os   # restrict cookie scope

# ── Mail ──────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=hello@handlelife.os
MAIL_FROM_NAME="${APP_NAME}"

# ── Redis ─────────────────────────────────────────────────────────────
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=
REDIS_PORT=6379
REDIS_CLIENT=phpredis

# ── Security: WAF + rate limits + HSTS ────────────────────────────────
SECURITY_WAF_ENABLED=true
SECURITY_HSTS_ENABLED=true
SECURITY_HSTS_MAX_AGE=31536000
SECURITY_HSTS_SUBDOMAINS=true
SECURITY_HSTS_PRELOAD=true
SECURITY_RATE_LEAD=5,1
SECURITY_RATE_WAITLIST=3,1
SECURITY_RATE_WEB=120,1

# ── Trusted proxies ───────────────────────────────────────────────────
# Comma-separated list of CDN / load-balancer IPs/CIDRs you trust to set
# X-Forwarded-* headers. Set to "*" only if you fully control all hops.
# Cloudflare ranges, AWS ELB ranges, etc. should be enumerated explicitly.
TRUSTED_PROXIES=

# ── Third-party (optional) ────────────────────────────────────────────
# TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=
# SENTRY_LARAVEL_DSN=
