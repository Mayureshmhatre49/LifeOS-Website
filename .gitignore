# ─────────────────────────────────────────────────────────────────────────────
# Repo-root ignore. Each app (HandleLifeOS, HandleLifeOSWebsite) also has its
# own .gitignore handling app-specific cases — these patterns cover cross-app
# noise plus the local-only large backups.
# ─────────────────────────────────────────────────────────────────────────────

# Local backups / archives — keep out of git
*.7z
*.zip
*.tar
*.tar.gz
*.tgz
*.rar
HandleLifeOS.7z

# Node / package managers
**/node_modules/
**/.pnp
**/.pnp.*
.yarn/cache
.yarn/install-state.gz
.yarn/build-state.yml

# Next.js
**/.next/
**/out/
**/.turbo/

# Build artifacts
**/dist/
**/build/
!public/build/
**/.cache/
**/coverage/

# Vite dev-server marker — NEVER commit, causes all assets to load from localhost:5173
**/public/hot

# PHP / Laravel (HandleLifeOSWebsite)
**/vendor/
**/storage/framework/cache/data/
**/storage/framework/sessions/
**/storage/framework/views/
**/storage/logs/
**/bootstrap/cache/*.php
!**/bootstrap/cache/.gitignore

# Env / secrets — NEVER commit
.env
.env.local
.env.*.local
*.env
*.pem
*.key

# IDE / OS
.DS_Store
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
!.vscode/launch.json
Thumbs.db
*.swp
*.swo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Local OS / tooling
~$*

# Build outputs occasionally captured during runs
**/build-output.txt
**/tsc-output.txt
